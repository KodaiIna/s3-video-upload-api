{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "S3": {
    "BucketName": "local-video-bucket",
    "Region": "ap-northeast-1",
    "KeyPrefix": "videos",
    "ServiceUrl": "http://localhost:4566",
    "ForcePathStyle": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  }
}
